{
  "name": "nodeflow-api",
  "version": "1.0.0",
  "description": "Production-grade developer workflow automation API with queues, webhooks, realtime updates, and file processing.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/workers/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "bootstrap": "tsx scripts/bootstrap.ts"
  },
  "keywords": [],
  "author": "Suleiman Abdulrahman",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@bull-board/api": "^8.0.0",
    "@bull-board/express": "^8.0.0",
    "@prisma/client": "^6.17.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "bullmq": "^5.61.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prisma": "^6.17.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
